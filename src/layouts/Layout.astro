---
import "../styles/global.css";
import "../styles/equalizer.css";
import Banner from "@/components/Banner.astro";
import CookieConsentBanner from "@/components/CookieConsentBanner.astro";
import { missingConfigs } from "@/lib/config-status";

interface Props {
  title?: string;
  ogImage?: string;
}

const { title = "BassMap PL", ogImage } = Astro.props;
---

<!doctype html>
<html lang="pl" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#08080c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Orbitron:wght@500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {ogImage && <meta property="og:image" content={ogImage} />}
  </head>
  <body class="antialiased">
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Uwaga:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Dokumentacja"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
    <CookieConsentBanner />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
