---
import { PRIVACY_POLICY_PATH, TERMS_PATH } from "@/lib/legal/paths";
import { CONTACT_EMAIL } from "@/lib/routes";
import { resolveSocialUrl, SITE_SOCIAL_FACEBOOK_URL, SITE_SOCIAL_INSTAGRAM_URL } from "@/lib/site";

interface Props {
  contactHref?: string;
  class?: string;
}

const { contactHref = `mailto:${CONTACT_EMAIL}`, class: className } = Astro.props;

const instagramUrl = resolveSocialUrl(SITE_SOCIAL_INSTAGRAM_URL);
const facebookUrl = resolveSocialUrl(SITE_SOCIAL_FACEBOOK_URL);

const linkClass = "hover:text-accent transition-colors hover:underline";
const separatorClass = "text-border";
const socialIconClass =
  "text-muted-foreground hover:text-accent flex h-8 w-8 items-center justify-center rounded-md transition-colors";
---

<nav
  class:list={[
    "text-muted-foreground flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs tracking-wider uppercase",
    className,
  ]}
  aria-label="Nawigacja stopki"
>
  <a href={contactHref} class:list={linkClass}>Kontakt</a>
  {
    instagramUrl || facebookUrl ? (
      <>
        <span aria-hidden="true" class:list={separatorClass}>
          ·
        </span>
        <div class="flex items-center gap-1">
          {instagramUrl ? (
            <a
              href={instagramUrl}
              aria-label="Instagram BassMap PL"
              class:list={socialIconClass}
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
              </svg>
            </a>
          ) : null}
          {facebookUrl ? (
            <a
              href={facebookUrl}
              aria-label="Facebook BassMap PL"
              class:list={socialIconClass}
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
              </svg>
            </a>
          ) : null}
        </div>
      </>
    ) : null
  }
  <span aria-hidden="true" class:list={separatorClass}>·</span>
  <a href={PRIVACY_POLICY_PATH} class:list={linkClass}>Polityka prywatności</a>
  <span aria-hidden="true" class:list={separatorClass}>·</span>
  <a href={TERMS_PATH} class:list={linkClass}>Regulamin</a>
</nav>
