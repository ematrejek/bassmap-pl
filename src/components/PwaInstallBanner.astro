---
import { shellBtnOutline } from "@/lib/shell-styles";

const STORAGE_KEY = "bassmap-pwa-install-dismissed-v2";
---

<div
  id="pwa-install-banner"
  role="region"
  aria-label="Zainstaluj aplikację BassMap"
  hidden
  class="border-primary/40 bg-card/95 text-foreground fixed inset-x-0 top-14 z-40 border-b px-4 py-3 shadow-lg backdrop-blur-md sm:top-16"
>
  <div class="mx-auto flex max-w-4xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="text-sm leading-relaxed">
      <p id="pwa-install-message" class="text-foreground font-medium">Zainstaluj BassMap na telefonie</p>
      <p id="pwa-install-hint" class="text-muted-foreground mt-1 hidden text-xs"></p>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <button
        id="pwa-install-action"
        type="button"
        hidden
        class:list={[
          shellBtnOutline,
          "focus-visible:ring-ring/50 inline-flex cursor-pointer items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium focus-visible:ring-2 focus-visible:outline-none",
        ]}
      >
        Zainstaluj aplikację
      </button>
      <button
        id="pwa-install-dismiss"
        type="button"
        aria-label="Zamknij"
        class:list={[
          shellBtnOutline,
          "focus-visible:ring-ring/50 inline-flex cursor-pointer items-center justify-center rounded-lg px-3 py-2 text-sm focus-visible:ring-2 focus-visible:outline-none",
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ STORAGE_KEY }}>
  (function initPwaInstallBanner() {
    const banner = document.getElementById("pwa-install-banner");
    const message = document.getElementById("pwa-install-message");
    const hint = document.getElementById("pwa-install-hint");
    const action = document.getElementById("pwa-install-action");
    const dismiss = document.getElementById("pwa-install-dismiss");

    if (!banner || !message || !hint || !action || !dismiss) {
      return;
    }

    // Closing the banner hides it only temporarily, so it can return later
    // (e.g. after the user uninstalls the app and revisits the site).
    const DISMISS_MS = 30 * 24 * 60 * 60 * 1000;

    const isStandalone =
      window.matchMedia("(display-mode: standalone)").matches ||
      /** @type {Window & { navigator: Navigator & { standalone?: boolean } }} */ (window).navigator.standalone ===
        true;

    if (isStandalone) {
      banner.remove();
      return;
    }

    function isDismissed() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return false;
        const ts = parseInt(raw, 10);
        if (Number.isNaN(ts)) return false;
        return Date.now() - ts < DISMISS_MS;
      } catch {
        return false;
      }
    }

    if (isDismissed()) {
      banner.remove();
      return;
    }

    function showBanner() {
      banner.removeAttribute("hidden");
    }

    function rememberDismiss() {
      try {
        localStorage.setItem(STORAGE_KEY, String(Date.now()));
      } catch {
        // Ignore storage failures.
      }
    }

    function dismissBanner() {
      rememberDismiss();
      banner.remove();
    }

    dismiss.addEventListener("click", dismissBanner);

    // If the app gets installed, drop the banner without a long-term dismiss.
    window.addEventListener("appinstalled", function () {
      banner.remove();
    });

    const ua = navigator.userAgent;
    const isIos = /iphone|ipad|ipod/i.test(ua) && !(/** @type {Window & { MSStream?: unknown }} */ (window).MSStream);
    const isMobile =
      isIos || /android|iemobile|blackberry|bada|mobile/i.test(ua) || window.matchMedia("(pointer: coarse)").matches;

    // Desktop / laptop: install prompt is unreliable here, so show an
    // informational note pointing users to the mobile install instead.
    if (!isMobile) {
      message.textContent = "Wersja mobilna dostępna";
      hint.textContent = "Otwórz BassMap na telefonie i dodaj do ekranu głównego, aby korzystać jak z aplikacji.";
      hint.classList.remove("hidden");
      showBanner();
      return;
    }

    // iOS: no automatic prompt, so show a manual instruction.
    if (isIos) {
      message.textContent = "Dodaj BassMap do ekranu głównego";
      hint.textContent = "W Safari: Udostępnij → Dodaj do ekranu początkowego";
      hint.classList.remove("hidden");
      showBanner();
      return;
    }

    // Android / Chromium mobile: use the native install prompt.
    /** @type {Event | null} */
    let deferredPrompt = null;

    window.addEventListener("beforeinstallprompt", function (event) {
      event.preventDefault();
      deferredPrompt = event;
      message.textContent = "Zainstaluj BassMap na telefonie";
      hint.textContent = "Szybki dostęp z ekranu głównego, bez sklepu z aplikacjami.";
      hint.classList.remove("hidden");
      action.removeAttribute("hidden");
      showBanner();
    });

    action.addEventListener("click", async function () {
      if (!deferredPrompt || typeof deferredPrompt !== "object" || !("prompt" in deferredPrompt)) {
        return;
      }
      const promptEvent = /** @type {{ prompt: () => Promise<void>; userChoice: Promise<{ outcome: string }> }} */ (
        deferredPrompt
      );
      await promptEvent.prompt();
      await promptEvent.userChoice;
      deferredPrompt = null;
      // Hide for now without a long-term dismiss; if installation succeeds the
      // standalone check removes it on next load, and if not it can return.
      banner.remove();
    });
  })();
</script>
