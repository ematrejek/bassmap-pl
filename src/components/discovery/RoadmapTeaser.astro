---
import { PUBLIC_ROADMAP_ITEMS } from "@/data/public-roadmap";
---

{
  PUBLIC_ROADMAP_ITEMS.length > 0 && (
    <section
      class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-xl"
      aria-labelledby="public-roadmap-heading"
    >
      <h2 id="public-roadmap-heading" class="text-sm font-semibold tracking-wide text-purple-200 uppercase">
        On the roadmap:
      </h2>
      <ul class="mt-3 space-y-2">
        {PUBLIC_ROADMAP_ITEMS.map((item) => (
          <li class="flex gap-2 text-sm text-blue-100/75">
            <span class="text-purple-300/80" aria-hidden="true">
              →
            </span>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
    </section>
  )
}
