---
import { PRIVACY_POLICY_PATH, TERMS_PATH } from "@/lib/legal/paths";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<footer class:list={["border-border/70 border-t py-4", className]} aria-label="Dokumenty prawne">
  <nav
    class="text-muted-foreground flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs tracking-wider uppercase"
  >
    <a href={PRIVACY_POLICY_PATH} class="hover:text-accent transition-colors hover:underline"> Polityka prywatności </a>
    <span aria-hidden="true" class="text-border">·</span>
    <a href={TERMS_PATH} class="hover:text-accent transition-colors hover:underline"> Regulamin </a>
  </nav>
</footer>
