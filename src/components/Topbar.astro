---
const { user, isAdmin } = Astro.locals;
---

<div
  class="mb-4 flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80"
>
  <a href="/" class="font-semibold text-purple-200 transition-colors hover:text-purple-100 hover:underline">
    Wydarzenia
  </a>

  <div class="flex items-center gap-3">
    {
      user ? (
        <>
          <span class="hidden text-blue-100/70 sm:inline">{user.email}</span>
          {isAdmin && (
            <a href="/admin" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Panel admina
            </a>
          )}
          <a href="/dashboard" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Dashboard
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Wyloguj
            </button>
          </form>
        </>
      ) : (
        <>
          <a href="/auth/signin" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Zaloguj się
          </a>
          <a href="/auth/signup" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Zarejestruj się
          </a>
        </>
      )
    }
  </div>
</div>
