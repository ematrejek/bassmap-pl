---
import { PRIVACY_POLICY_PATH } from "@/lib/legal/paths";
import { shellBtnOutline, shellLink } from "@/lib/shell-styles";

const STORAGE_KEY = "bassmap-cookie-notice-dismissed-v1";
---

<div
  id="cookie-consent-banner"
  role="region"
  aria-label="Informacja o plikach cookies"
  hidden
  class="border-border bg-card/95 text-foreground fixed inset-x-0 bottom-0 z-50 border-t px-4 py-3 shadow-lg backdrop-blur-md"
>
  <div class="mx-auto flex max-w-4xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-muted-foreground text-sm leading-relaxed">
      Używamy wyłącznie niezbędnych plików cookies do utrzymania sesji logowania (Supabase Auth). Nie stosujemy cookies
      marketingowych ani śledzących. Szczegóły w
      <a href={PRIVACY_POLICY_PATH} class:list={[shellLink, "underline-offset-2 hover:underline"]}>
        Polityce prywatności
      </a>.
    </p>
    <button
      id="cookie-consent-dismiss"
      type="button"
      class:list={[
        shellBtnOutline,
        "focus-visible:ring-ring/50 inline-flex shrink-0 cursor-pointer items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium focus-visible:ring-2 focus-visible:outline-none",
      ]}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
      Rozumiem
    </button>
  </div>
</div>

<script is:inline define:vars={{ STORAGE_KEY }}>
  (function initCookieConsentBanner() {
    const banner = document.getElementById("cookie-consent-banner");
    const dismissButton = document.getElementById("cookie-consent-dismiss");
    if (!banner || !dismissButton) {
      return;
    }

    let dismissed = false;
    try {
      dismissed = localStorage.getItem(STORAGE_KEY) === "1";
    } catch {
      dismissed = false;
    }

    if (dismissed) {
      banner.remove();
      return;
    }

    banner.removeAttribute("hidden");

    dismissButton.addEventListener("click", function () {
      try {
        localStorage.setItem(STORAGE_KEY, "1");
      } catch {
        // Ignore storage failures; banner still closes for this page view.
      }
      banner.remove();
    });
  })();
</script>
