---
import AppBrand from "@/components/shell/AppBrand.astro";
import SiteFooterNav from "@/components/SiteFooterNav.astro";
import { HOME_PATH } from "@/lib/routes";
---

<footer class="home-panel-legal relative" aria-label="Stopka serwisu">
  <div class="grid-backdrop absolute inset-0 opacity-40" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="border-border/70 flex flex-col items-center justify-between gap-8 border-t pt-8 sm:flex-row">
      <AppBrand />
      <SiteFooterNav contactHref={`${HOME_PATH}#contact`} />
    </div>
  </div>
</footer>
