---
import AppBrand from "@/components/shell/AppBrand.astro";
import AppHeaderActions from "@/components/shell/AppHeaderActions.astro";
import AppMenu from "@/components/shell/AppMenu";
import NotificationBell from "@/components/notifications/NotificationBell";
import SiteFooter from "@/components/SiteFooter.astro";

interface Props {
  showFooter?: boolean;
  /** Full-bleed homepage: no shell padding, content edge-to-edge. */
  immersive?: boolean;
  /** Strony logowania/rejestracji – nagłówek jak dla niezalogowanego. */
  authHeader?: boolean;
}

const { showFooter = true, immersive = false, authHeader = false } = Astro.props;
const { user, isAdmin, isOrganizer } = Astro.locals;
const userEmail = user?.email ?? null;
const headerUserEmail = authHeader ? null : userEmail;
const headerIsAdmin = authHeader ? false : isAdmin;
const headerIsOrganizer = authHeader ? false : isOrganizer;
---

<div class="bg-background relative min-h-screen w-full overflow-x-hidden">
  <div class:list={["relative z-10 flex min-h-screen flex-col", !immersive && "px-4 sm:px-6"]}>
    <header
      class="border-border/70 bg-background/70 pointer-events-none fixed top-0 right-0 left-0 z-50 flex items-center justify-between gap-3 border-b px-3 py-2.5 backdrop-blur-md sm:px-4 sm:py-3 md:px-6"
      aria-label="Nawigacja globalna"
    >
      <div class="pointer-events-auto shrink-0">
        <AppBrand compact />
      </div>

      <div class="pointer-events-auto flex min-w-0 items-center justify-end gap-1.5 sm:gap-2">
        <AppHeaderActions userEmail={headerUserEmail} isAdmin={headerIsAdmin} />
        {
          headerUserEmail ? (
            <NotificationBell client:only="react">
              <button
                slot="fallback"
                type="button"
                disabled
                aria-label="Ładowanie powiadomień"
                class="font-heading border-border bg-card/60 text-foreground shadow-glow-violet inline-flex h-9 w-9 items-center justify-center rounded-md border p-0 uppercase opacity-80 backdrop-blur-md md:h-10 md:w-auto md:px-3"
              >
                <span class="md:not-sr-only">Powiadomienia</span>
                <span class="sr-only md:hidden">Powiadomienia</span>
              </button>
            </NotificationBell>
          ) : null
        }
        <AppMenu
          userEmail={headerUserEmail}
          isAdmin={headerIsAdmin}
          isOrganizer={headerIsOrganizer}
          client:only="react"
        >
          <button
            slot="fallback"
            type="button"
            disabled
            aria-label="Otwórz menu nawigacji"
            class="font-heading border-border bg-card/60 text-foreground shadow-glow-violet inline-flex h-9 w-9 items-center justify-center rounded-md border p-0 text-sm uppercase opacity-80 backdrop-blur-md md:h-10 md:w-auto md:gap-2 md:px-3"
          >
            <span class="hidden md:inline">Menu</span>
            <span class="text-accent text-base leading-none md:hidden" aria-hidden="true"> ≡ </span>
          </button>
        </AppMenu>
      </div>
    </header>

    <main class="flex-1 pt-14 sm:pt-16">
      <slot />

      {showFooter && <SiteFooter />}
    </main>
  </div>
</div>
