---
import SiteFooter from "@/components/SiteFooter.astro";
import Topbar from "@/components/Topbar.astro";
import LegalProse from "@/components/legal/LegalProse.astro";
import Layout from "@/layouts/Layout.astro";
import { LEGAL_UPDATED_AT } from "@/lib/legal/paths";

interface Props {
  title: string;
  pageTitle: string;
}

const { title, pageTitle } = Astro.props;
---

<Layout title={title}>
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 flex min-h-screen flex-col p-4 sm:p-8">
      <Topbar />

      <div class="mx-auto w-full max-w-2xl flex-1 px-2 py-8 sm:px-4">
        <article class="rounded-2xl border border-white/10 bg-white/5 p-6 text-white backdrop-blur-xl sm:p-8">
          <header class="mb-8 space-y-2 border-b border-white/10 pb-6">
            <h1
              class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
            >
              {pageTitle}
            </h1>
            <p class="text-sm text-blue-100/60">BassMap PL · bassmap.pl</p>
            <p class="text-sm text-blue-100/60">Data ostatniej aktualizacji: {LEGAL_UPDATED_AT}</p>
          </header>

          <LegalProse>
            <slot />
          </LegalProse>
        </article>
      </div>

      <SiteFooter />
    </div>
  </div>
</Layout>
