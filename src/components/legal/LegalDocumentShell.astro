---
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import LegalProse from "@/components/legal/LegalProse.astro";
import { LEGAL_UPDATED_AT } from "@/lib/legal/paths";

interface Props {
  title: string;
  pageTitle: string;
}

const { title, pageTitle } = Astro.props;
---

<Layout title={title}>
  <AppShell>
    <div class="mx-auto w-full max-w-2xl flex-1 px-2 py-8 sm:px-4">
      <article class="surface-panel text-foreground p-6 sm:p-8">
        <header class="border-border/70 mb-8 space-y-2 border-b pb-6">
          <h1 class="font-heading text-foreground text-3xl font-black tracking-tight uppercase">
            {pageTitle}
          </h1>
          <p class="text-muted-foreground text-sm">BassMap PL · bassmap.pl</p>
          <p class="text-muted-foreground text-sm">Data ostatniej aktualizacji: {LEGAL_UPDATED_AT}</p>
        </header>

        <LegalProse>
          <slot />
        </LegalProse>
      </article>
    </div>
  </AppShell>
</Layout>
