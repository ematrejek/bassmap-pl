---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;

Astro.response.status = 403;
---

<Layout title="Brak uprawnień">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Brak uprawnień
      </h1>
      <p class="text-blue-100/80">Nie masz uprawnień administratora, aby otworzyć ten panel.</p>
      <a
        href="/"
        class="mt-6 inline-flex rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
      >
        Wróć na stronę główną
      </a>
    </div>
  </div>
</Layout>
