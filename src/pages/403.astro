---
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { HOME_PATH } from "@/lib/routes";
import { shellBtnOutline } from "@/lib/shell-styles";

export const prerender = false;

Astro.response.status = 403;
---

<Layout title="Brak uprawnień">
  <AppShell showFooter={true}>
    <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center px-4 py-8">
      <div class="surface-panel p-8 text-center">
        <h1 class="font-heading text-foreground mb-4 text-3xl font-black tracking-tight uppercase">Brak uprawnień</h1>
        <p class="text-muted-foreground">Nie masz uprawnień administratora, aby otworzyć ten panel.</p>
        <a href={HOME_PATH} class:list={[shellBtnOutline, "mt-6 inline-flex rounded-lg px-4 py-2 text-sm"]}>
          Wróć na stronę główną
        </a>
      </div>
    </div>
  </AppShell>
</Layout>
