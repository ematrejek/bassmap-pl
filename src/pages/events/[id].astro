---
import EventCoverImage from "@/components/discovery/EventCoverImage";
import EventSuggestChangesForm from "@/components/fan/EventSuggestChangesForm";
import AppShell from "@/components/shell/AppShell.astro";
import {
  formatEventAddress,
  formatEventDate,
  formatEventPrice,
  formatEventVenueLine,
  isUpcomingEvent,
} from "@/lib/events/format";
import { DISCOVERY_PATH } from "@/lib/routes";
import { getPublishedEventById } from "@/lib/services/events";
import { getEventCoverUrl } from "@/lib/storage/event-covers";
import { createClient } from "@/lib/supabase";
import Layout from "@/layouts/Layout.astro";
import { shellBtnPrimary, shellLink } from "@/lib/shell-styles";
import { SUBGENRE_LABELS } from "@/types";
import { SUPABASE_URL } from "astro:env/server";

export const prerender = false;

const { id } = Astro.params;
const { user, isAdmin } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const event = supabase && id ? await getPublishedEventById(supabase, id) : null;
const isLoggedIn = Boolean(user);
const eventPagePath = id ? `/events/${id}` : DISCOVERY_PATH;

if (!event) {
  Astro.response.status = 404;
}

const coverUrl = event && SUPABASE_URL ? getEventCoverUrl(event.coverPath, SUPABASE_URL) : null;
const eventDescription = event?.description?.trim() ?? "";
const showSuggestionForm = Boolean(event && isUpcomingEvent(event.startsAt));
---

<Layout title={event ? `${event.name} – BassMap PL` : "Nie znaleziono – BassMap PL"} ogImage={coverUrl ?? undefined}>
  <AppShell>
    <div class="mx-auto w-full max-w-2xl flex-1 px-2 py-8 sm:px-4">
      {
        !event ? (
          <div class="surface-panel p-8 text-center">
            <h1 class="font-heading text-foreground text-2xl font-black uppercase">Nie znaleziono wydarzenia</h1>
            <p class="text-muted-foreground mt-2">
              To wydarzenie nie istnieje, zakończyło się lub nie jest już publicznie dostępne.
            </p>
            <a
              href={DISCOVERY_PATH}
              class:list={[shellBtnPrimary, "mt-6 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm"]}
            >
              ← Wróć do listy
            </a>
          </div>
        ) : (
          <article class="surface-panel text-foreground space-y-6 p-6 sm:p-8">
            <div>
              <a href={DISCOVERY_PATH} class:list={[shellLink, "text-sm hover:underline"]}>
                ← Wróć do listy
              </a>
            </div>

            <EventCoverImage
              client:load
              coverUrl={coverUrl}
              alt={`Okładka: ${event.name}`}
              variant="hero"
              coverAspect={event.coverAspect}
            />

            <header class="space-y-3">
              <h1 class="font-heading text-foreground text-3xl font-black tracking-tight uppercase">{event.name}</h1>
              <p class="text-muted-foreground text-lg">{formatEventDate(event.startsAt)}</p>
              <p class="text-muted-foreground">{formatEventVenueLine(event)}</p>
              {formatEventAddress(event) ? (
                <p class="text-muted-foreground text-sm">{formatEventAddress(event)}</p>
              ) : (
                <p class="text-muted-foreground text-sm italic">
                  Dokładny adres zostanie podany na miejscu wydarzenia.
                </p>
              )}
              <p class="text-accent text-lg font-medium">{formatEventPrice(event)}</p>
            </header>

            {eventDescription ? (
              <section class="space-y-2">
                <h2 class="text-accent text-sm font-semibold tracking-wide uppercase">Opis</h2>
                <p class="text-muted-foreground whitespace-pre-wrap">{eventDescription}</p>
              </section>
            ) : null}

            <section class="space-y-2">
              <h2 class="text-accent text-sm font-semibold tracking-wide uppercase">Podgatunki</h2>
              <div class="flex flex-wrap gap-2">
                {event.subgenres.map((subgenre) => (
                  <span class="border-primary/30 bg-primary/10 text-foreground inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium">
                    {SUBGENRE_LABELS[subgenre]}
                  </span>
                ))}
              </div>
            </section>

            <section class="space-y-2">
              <h2 class="text-accent text-sm font-semibold tracking-wide uppercase">Lineup</h2>
              {event.lineup && event.lineup.length > 0 ? (
                <ul class="text-muted-foreground list-inside list-disc space-y-1">
                  {event.lineup.map((artist) => (
                    <li>{artist}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-muted-foreground">Brak potwierdzonego lineupu.</p>
              )}
            </section>

            {showSuggestionForm && !isAdmin ? (
              <section class="space-y-4">
                <h2 class="text-accent text-sm font-semibold tracking-wide uppercase">Sugeruj zmiany</h2>
                <EventSuggestChangesForm
                  client:visible
                  event={event}
                  isLoggedIn={isLoggedIn}
                  isAdmin={isAdmin}
                  redirectPath={eventPagePath}
                />
              </section>
            ) : null}

            {event.ticketUrl && (
              <a
                href={event.ticketUrl}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[shellBtnPrimary, "inline-flex h-9 items-center justify-center rounded-md px-4 text-sm"]}
              >
                Kup bilet
              </a>
            )}
          </article>
        )
      }
    </div>
  </AppShell>
</Layout>
