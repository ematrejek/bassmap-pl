---
import AppShell from "@/components/shell/AppShell.astro";
import MyEventsPage from "@/components/fan/MyEventsPage";
import Layout from "@/layouts/Layout.astro";
import type { Event, EventWithCoverUrl } from "@/types";
import { listEventsByCreator } from "@/lib/services/events";
import { listEventsForUserAttendance } from "@/lib/services/event-attendance";
import { listChangeSuggestionsForFan } from "@/lib/services/change-suggestions";
import { formatSuggestionSummary } from "@/lib/events/suggestion-format";
import { enrichEventWithCoverUrl } from "@/lib/storage/event-covers";
import { shellHeading, shellTextMuted } from "@/lib/shell-styles";
import { createClient } from "@/lib/supabase";
import { SUPABASE_URL } from "astro:env/server";

export const prerender = false;

const { user } = Astro.locals;
const submitted = Astro.url.searchParams.get("submitted") === "1";
const suggestionSubmitted = Astro.url.searchParams.get("suggestionSubmitted") === "1";

const supabase = createClient(Astro.request.headers, Astro.cookies);
const listResult = supabase && user ? await listEventsByCreator(supabase, user.id) : { data: [] as Event[] };
const suggestionsResult = supabase && user ? await listChangeSuggestionsForFan(supabase, user.id) : { data: [] };
const submittedEvents: Event[] = "data" in listResult ? listResult.data : [];
const changeSuggestions =
  "data" in suggestionsResult
    ? suggestionsResult.data.map((suggestion) => ({
        id: suggestion.id,
        eventId: suggestion.eventId,
        eventName: suggestion.eventName,
        summary: formatSuggestionSummary({
          body: suggestion.body,
          payload: suggestion.payload,
        }),
        status: suggestion.status,
        createdAt: suggestion.createdAt,
      }))
    : [];
const listError = "error" in listResult ? listResult.error : null;
const suggestionsError = "error" in suggestionsResult ? suggestionsResult.error : null;

const goingResult = supabase && user ? await listEventsForUserAttendance(supabase, user.id, "going") : { data: [] };
const interestedResult =
  supabase && user ? await listEventsForUserAttendance(supabase, user.id, "interested") : { data: [] };
const goingEventsRaw: Event[] = "data" in goingResult ? goingResult.data : [];
const interestedEventsRaw: Event[] = "data" in interestedResult ? interestedResult.data : [];
const attendanceError =
  ["error" in goingResult ? goingResult.error : null, "error" in interestedResult ? interestedResult.error : null]
    .filter(Boolean)
    .join(" ") || null;

const supabaseUrl = SUPABASE_URL ?? "";
function enrichEvents(events: Event[]): EventWithCoverUrl[] {
  return supabaseUrl
    ? events.map((event) => enrichEventWithCoverUrl(event, supabaseUrl))
    : events.map((event) => ({ ...event, coverUrl: null }));
}

const goingEvents = enrichEvents(goingEventsRaw);
const interestedEvents = enrichEvents(interestedEventsRaw);
---

<Layout title="Moje wydarzenia">
  <AppShell showFooter={true}>
    <div class="mx-auto max-w-6xl px-4 py-8">
      {
        listError ? (
          <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
            {listError}
          </p>
        ) : null
      }

      {
        suggestionsError ? (
          <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
            {suggestionsError}
          </p>
        ) : null
      }

      {
        attendanceError ? (
          <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
            {attendanceError}
          </p>
        ) : null
      }

      <div class="mb-10">
        <h1 class:list={shellHeading}>Moje wydarzenia</h1>
        <p class:list={["mt-1 text-sm", shellTextMuted]}>
          Na które idziesz, które Cię interesują i które zgłaszasz do moderacji.
        </p>
      </div>

      <MyEventsPage
        submittedEvents={submittedEvents}
        changeSuggestions={changeSuggestions}
        goingEvents={goingEvents}
        interestedEvents={interestedEvents}
        submitted={submitted}
        suggestionSubmitted={suggestionSubmitted}
        client:load
      />
    </div>
  </AppShell>
</Layout>
