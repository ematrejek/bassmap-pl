---
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { shellBtnOutline } from "@/lib/shell-styles";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <AppShell showFooter={true}>
    <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center px-4 py-8">
      <div class="surface-panel p-8 text-center">
        <h1 class="font-heading text-foreground mb-4 text-3xl font-black tracking-tight uppercase">Dashboard</h1>
        <p class="text-muted-foreground">
          Witaj, <span class="text-foreground font-semibold">{user?.email}</span>
        </p>
        <p class="text-muted-foreground mt-2 text-sm">Ta strona jest tylko dla zalogowanych użytkowników.</p>
        <form method="POST" action="/api/auth/signout" class="mt-6">
          <button type="submit" class:list={[shellBtnOutline, "rounded-lg px-4 py-2 text-sm"]}> Wyloguj się </button>
        </form>
      </div>
    </div>
  </AppShell>
</Layout>
