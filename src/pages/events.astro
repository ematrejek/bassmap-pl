---
import DiscoveryShell from "@/components/discovery/DiscoveryShell";
import EventDiscoveryListStatic from "@/components/discovery/EventDiscoveryListStatic.astro";
import EventFiltersStatic from "@/components/discovery/EventFiltersStatic.astro";
import AppShell from "@/components/shell/AppShell.astro";
import { hasActiveFanFilters } from "@/lib/events/discovery-page";
import { parseFanFilters } from "@/lib/events/fan-schema";
import { getGoingCountsByEventIds, getUserAttendanceByEventIds } from "@/lib/services/event-attendance";
import { listDistinctCities, listPublishedEvents } from "@/lib/services/events";
import { enrichEventWithCoverUrl } from "@/lib/storage/event-covers";
import { createClient } from "@/lib/supabase";
import Layout from "@/layouts/Layout.astro";
import { shellHeading, shellPanelFlat, shellTextMuted } from "@/lib/shell-styles";
import { SUPABASE_URL } from "astro:env/server";

export const prerender = false;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const { user } = Astro.locals;
const isLoggedIn = Boolean(user);
const currentFilters = parseFanFilters(Astro.url.searchParams);

const listResult = supabase ? await listPublishedEvents(supabase, currentFilters) : { data: [] };
const citiesResult = supabase ? await listDistinctCities(supabase) : { data: [] };

const rawEvents = "data" in listResult ? listResult.data : [];
const eventIds = rawEvents.map((event) => event.id);
const goingCountsResult =
  supabase && eventIds.length > 0 ? await getGoingCountsByEventIds(supabase, eventIds) : { data: {} };
const goingCounts = "data" in goingCountsResult ? goingCountsResult.data : {};
const goingCountsError = "error" in goingCountsResult ? goingCountsResult.error : null;
const userAttendanceResult =
  supabase && user && eventIds.length > 0
    ? await getUserAttendanceByEventIds(supabase, user.id, eventIds)
    : { data: {} };
const userAttendance = "data" in userAttendanceResult ? userAttendanceResult.data : {};
const userAttendanceError = "error" in userAttendanceResult ? userAttendanceResult.error : null;
const supabaseUrl = SUPABASE_URL ?? "";
const events = supabaseUrl
  ? rawEvents.map((event) => ({
      ...enrichEventWithCoverUrl(event, supabaseUrl),
      goingCount: goingCounts[event.id] ?? 0,
      userAttendanceStatus: userAttendance[event.id] ?? null,
    }))
  : rawEvents.map((event) => ({
      ...event,
      coverUrl: null as string | null,
      goingCount: goingCounts[event.id] ?? 0,
      userAttendanceStatus: userAttendance[event.id] ?? null,
    }));
const cities = "data" in citiesResult ? citiesResult.data : [];
const listError =
  [
    "error" in listResult ? listResult.error : null,
    "error" in citiesResult ? citiesResult.error : null,
    goingCountsError,
    userAttendanceError,
  ]
    .filter(Boolean)
    .join(" ") || null;

const hasActiveFilters = hasActiveFanFilters(currentFilters);
---

<Layout title="BassMap PL – Find the place, drop the bass!">
  <AppShell>
    <div class="mx-auto w-full max-w-6xl flex-1 space-y-8 px-2 py-8 sm:px-4">
      <DiscoveryShell
        events={events}
        cities={cities}
        currentFilters={currentFilters}
        listError={listError}
        isLoggedIn={isLoggedIn}
        client:only="react"
      >
        <div slot="fallback" class="space-y-6">
          <div>
            <h1 class:list={shellHeading}>
              MAP THE <span class="text-primary text-glow-violet">BASS</span>!
            </h1>
            <p class:list={["mt-1 text-sm", shellTextMuted]}>
              Filtruj po dacie, mieście, podgatunku i cenie – znajdź imprezę na liście lub mapie.
            </p>
          </div>

          {
            listError ? (
              <p class="flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
                {listError}
              </p>
            ) : null
          }

          <div class="grid gap-6 md:grid-cols-2 md:items-start">
            <EventFiltersStatic cities={cities} currentFilters={currentFilters} />
            <div
              class:list={[
                "flex min-h-[320px] items-center justify-center p-6 text-center text-sm",
                shellPanelFlat,
                shellTextMuted,
              ]}
              aria-hidden="true"
            >
              Mapa interaktywna załaduje się po włączeniu JavaScript.
            </div>
          </div>

          <EventDiscoveryListStatic events={events} hasActiveFilters={hasActiveFilters} />
        </div>
      </DiscoveryShell>
    </div>
  </AppShell>
</Layout>
