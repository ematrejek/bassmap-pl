---
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { MY_EVENTS_PATH, PROFILE_PATH } from "@/lib/routes";
import { shellHeading, shellLink, shellTextMuted } from "@/lib/shell-styles";

export const prerender = false;
---

<Layout title="Moja ekipa">
  <AppShell showFooter={true}>
    <div class="mx-auto flex w-full max-w-lg flex-1 flex-col justify-center px-4 py-8">
      <div class="surface-panel p-8 text-center">
        <h1 class:list={[shellHeading, "mb-3"]}>Moja ekipa</h1>
        <p class:list={["text-sm", shellTextMuted]}>Wkrótce – tutaj będziesz mógł zarządzać swoją ekipą.</p>
        <div class="mt-6 flex flex-col gap-2 text-sm">
          <a href={MY_EVENTS_PATH} class:list={[shellLink, "hover:underline"]}>Moje eventy</a>
          <a href={PROFILE_PATH} class:list={[shellLink, "hover:underline"]}>Mój profil</a>
        </div>
      </div>
    </div>
  </AppShell>
</Layout>
