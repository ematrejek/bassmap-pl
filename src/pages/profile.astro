---
import AppShell from "@/components/shell/AppShell.astro";
import DeleteAccountSection from "@/components/fan/DeleteAccountSection";
import ProfileSection from "@/components/fan/ProfileSection";
import Layout from "@/layouts/Layout.astro";
import { PRIVACY_POLICY_PATH } from "@/lib/legal/paths";
import { listEventsForUserAttendance } from "@/lib/services/event-attendance";
import { enrichEventWithCoverUrl } from "@/lib/storage/event-covers";
import { shellLink, shellTextMuted } from "@/lib/shell-styles";
import { createClient } from "@/lib/supabase";
import type { Event, EventWithCoverUrl } from "@/types";
import { SUPABASE_URL } from "astro:env/server";

export const prerender = false;

const { user, isAdmin } = Astro.locals;
const email = user?.email ?? "";

const supabase = createClient(Astro.request.headers, Astro.cookies);
const goingResult = supabase && user ? await listEventsForUserAttendance(supabase, user.id, "going") : { data: [] };
const goingEventsRaw: Event[] = "data" in goingResult ? goingResult.data : [];
const goingError = "error" in goingResult ? goingResult.error : null;
const supabaseUrl = SUPABASE_URL ?? "";
const goingEvents: EventWithCoverUrl[] = supabaseUrl
  ? goingEventsRaw.map((event) => enrichEventWithCoverUrl(event, supabaseUrl))
  : goingEventsRaw.map((event) => ({ ...event, coverUrl: null }));
---

<Layout title="Mój profil">
  <AppShell showFooter={true}>
    {
      goingError ? (
        <div class="mx-auto max-w-6xl px-4 pt-8">
          <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
            {goingError}
          </p>
        </div>
      ) : null
    }
    {email ? <ProfileSection email={email} goingEvents={goingEvents} client:load /> : null}
    {
      email && !isAdmin ? (
        <DeleteAccountSection client:load />
      ) : isAdmin ? (
        <section class="border-border border-t py-12">
          <div class="mx-auto max-w-6xl px-4">
            <p class:list={["max-w-2xl text-sm leading-relaxed", shellTextMuted]}>
              Administrator usuwa konto na wniosek e-mail – szczegóły w{" "}
              <a href={PRIVACY_POLICY_PATH} class:list={[shellLink, "hover:underline"]}>
                polityce prywatności (§5.1)
              </a>
              .
            </p>
          </div>
        </section>
      ) : null
    }
  </AppShell>
</Layout>
