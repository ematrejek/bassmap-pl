---
import ForumView from "@/components/forum/ForumView";
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { getForumCommentCounts } from "@/lib/services/forum-comments";
import { listForumThreads } from "@/lib/services/forum-threads";
import { createClient } from "@/lib/supabase";

export const prerender = false;

const { user, isAdmin } = Astro.locals;
const isLoggedIn = Boolean(user);
const supabase = createClient(Astro.request.headers, Astro.cookies);

const threadsResult = supabase ? await listForumThreads(supabase, { limit: 200, offset: 0 }) : null;
const threads = threadsResult && "data" in threadsResult ? threadsResult.data : [];

const countsResult =
  supabase && threads.length > 0
    ? await getForumCommentCounts(
        supabase,
        threads.map((t) => t.id),
      )
    : null;
const replyCounts = countsResult && "data" in countsResult ? countsResult.data : {};
---

<Layout title="Forum – BassMap PL">
  <AppShell immersive={true}>
    <ForumView
      client:only="react"
      initialThreads={threads}
      replyCounts={replyCounts}
      isLoggedIn={isLoggedIn}
      isAdmin={isAdmin}
    />
  </AppShell>
</Layout>
