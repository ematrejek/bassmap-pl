---
import { z } from "zod";
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import EventForm from "@/components/admin/EventForm";
import { getEventById } from "@/lib/services/events";
import { createClient } from "@/lib/supabase";

export const prerender = false;

const idSchema = z.string().uuid();
const idResult = idSchema.safeParse(Astro.params.id);

let event = null;
let notFound = false;

if (idResult.success) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    event = await getEventById(supabase, idResult.data);
  }
  if (!event) {
    notFound = true;
    Astro.response.status = 404;
  }
} else {
  notFound = true;
  Astro.response.status = 404;
}
---

<Layout title={notFound ? "Nie znaleziono" : `Edycja: ${event?.name ?? ""}`}>
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 p-4 sm:p-8">
      <Topbar />

      <div class="mx-auto max-w-2xl px-2 py-8 sm:px-4">
        {
          notFound ? (
            <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
              <h1 class="mb-2 text-2xl font-bold">Nie znaleziono wydarzenia</h1>
              <p class="text-blue-100/70">Sprawdź link lub wróć do listy.</p>
              <a
                href="/admin"
                class="mt-6 inline-block text-purple-300 transition-colors hover:text-purple-100 hover:underline"
              >
                ← Wróć do listy
              </a>
            </div>
          ) : (
            <>
              <div class="mb-6">
                <a
                  href="/admin"
                  class="text-sm text-purple-300 transition-colors hover:text-purple-100 hover:underline"
                >
                  ← Wróć do listy
                </a>
                <h1 class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
                  Edytuj wydarzenie
                </h1>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl sm:p-8">
                <EventForm mode="edit" initialEvent={event} client:load />
              </div>
            </>
          )
        }
      </div>
    </div>
  </div>
</Layout>
