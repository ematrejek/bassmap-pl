---
import { z } from "zod";
import { SUPABASE_URL } from "astro:env/server";
import Layout from "@/layouts/Layout.astro";
import AppShell from "@/components/shell/AppShell.astro";
import EventForm from "@/components/admin/EventForm";
import { getEventById } from "@/lib/services/events";
import { getEventCoverUrl } from "@/lib/storage/event-covers";
import { ADMIN_PATH } from "@/lib/routes";
import { shellHeading, shellLink } from "@/lib/shell-styles";
import { createClient } from "@/lib/supabase";

export const prerender = false;

const idSchema = z.string().uuid();
const idResult = idSchema.safeParse(Astro.params.id);

let event = null;
let notFound = false;

if (idResult.success) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    event = await getEventById(supabase, idResult.data);
  }
  if (!event) {
    notFound = true;
    Astro.response.status = 404;
  }
} else {
  notFound = true;
  Astro.response.status = 404;
}

const coverUploadError =
  Astro.url.searchParams.get("coverError") === "upload"
    ? "Wydarzenie zapisane, ale okładka nie została wgrana. Spróbuj dodać ją ponownie."
    : null;

const initialCoverUrl = event && SUPABASE_URL ? getEventCoverUrl(event.coverPath, SUPABASE_URL) : null;
---

<Layout title={notFound ? "Nie znaleziono" : `Edycja: ${event?.name ?? ""}`}>
  <AppShell showFooter={false}>
    <div class="mx-auto max-w-2xl px-2 py-8 sm:px-4">
      {
        notFound ? (
          <div class="surface-panel p-8 text-center">
            <h1 class="font-heading text-foreground mb-2 text-2xl font-black uppercase">Nie znaleziono wydarzenia</h1>
            <p class="text-muted-foreground">Sprawdź link lub wróć do listy.</p>
            <a href={ADMIN_PATH} class:list={[shellLink, "mt-6 inline-block hover:underline"]}>
              ← Wróć do listy
            </a>
          </div>
        ) : (
          <>
            <div class="mb-6">
              <a href={ADMIN_PATH} class:list={[shellLink, "text-sm hover:underline"]}>
                {" "}
                ← Wróć do listy{" "}
              </a>
              <h1 class:list={[shellHeading, "mt-2"]}>Edytuj wydarzenie</h1>
            </div>

            <div class="surface-panel p-6 sm:p-8">
              <EventForm
                mode="edit"
                initialEvent={event ?? undefined}
                initialCoverUrl={initialCoverUrl}
                serverError={coverUploadError}
                client:load
              />
            </div>
          </>
        )
      }
    </div>
  </AppShell>
</Layout>
