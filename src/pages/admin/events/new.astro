---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import EventForm from "@/components/admin/EventForm";

export const prerender = false;
---

<Layout title="Nowe wydarzenie">
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 p-4 sm:p-8">
      <Topbar />

      <div class="mx-auto max-w-2xl px-2 py-8 sm:px-4">
        <div class="mb-6">
          <a href="/admin" class="text-sm text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            ← Wróć do listy
          </a>
          <h1
            class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
          >
            Dodaj wydarzenie
          </h1>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl sm:p-8">
          <EventForm mode="create" client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>
