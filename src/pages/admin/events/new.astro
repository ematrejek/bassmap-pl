---
import Layout from "@/layouts/Layout.astro";
import AppShell from "@/components/shell/AppShell.astro";
import EventForm from "@/components/admin/EventForm";
import { ADMIN_PATH } from "@/lib/routes";
import { shellHeading, shellLink } from "@/lib/shell-styles";

export const prerender = false;
---

<Layout title="Nowe wydarzenie">
  <AppShell showFooter={false}>
    <div class="mx-auto max-w-2xl px-2 py-8 sm:px-4">
      <div class="mb-6">
        <a href={ADMIN_PATH} class:list={[shellLink, "text-sm hover:underline"]}> ← Wróć do listy </a>
        <h1 class:list={[shellHeading, "mt-2"]}>Dodaj wydarzenie</h1>
      </div>

      <div class="surface-panel p-6 sm:p-8">
        <EventForm mode="create" client:only="react" />
      </div>
    </div>
  </AppShell>
</Layout>
