---
import Layout from "@/layouts/Layout.astro";
import AppShell from "@/components/shell/AppShell.astro";
import AdminEventsTable from "@/components/admin/AdminEventsTable";
import ChangeSuggestionsTable, { type ChangeSuggestionTableRow } from "@/components/admin/ChangeSuggestionsTable";
import { resolveSubmitterProfiles } from "@/lib/auth/submitter-profile";
import { listChangeSuggestionsForAdmin, type AdminChangeSuggestionListItem } from "@/lib/services/change-suggestions";
import { listEventsForAdmin } from "@/lib/services/events";
import { enrichEventWithCoverUrl } from "@/lib/storage/event-covers";
import { ADMIN_PATH } from "@/lib/routes";
import { shellBtnPrimary, shellHeading, shellTextMuted } from "@/lib/shell-styles";
import { createClient } from "@/lib/supabase";
import type { AdminEventRow, Event } from "@/types";
import { SUPABASE_URL } from "astro:env/server";

export const prerender = false;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const listResult = supabase ? await listEventsForAdmin(supabase) : { data: [] };
const suggestionsResult = supabase ? await listChangeSuggestionsForAdmin(supabase) : { data: [] };
const rawEvents: Event[] = "data" in listResult ? listResult.data : [];
const rawSuggestions: AdminChangeSuggestionListItem[] = "data" in suggestionsResult ? suggestionsResult.data : [];
const suggestionsError = "error" in suggestionsResult ? suggestionsResult.error : null;
const supabaseUrl = SUPABASE_URL ?? "";

function isFanSubmission(event: Event): boolean {
  return event.status === "pending" && event.createdBy !== null;
}

const fanPending = rawEvents
  .filter(isFanSubmission)
  .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
const otherEvents = rawEvents.filter((event) => !isFanSubmission(event));

const submitterIds = fanPending.map((event) => event.createdBy).filter((id): id is string => id !== null);
const submitterProfiles = await resolveSubmitterProfiles(submitterIds);

const suggestionSubmitterIds = rawSuggestions.map((item) => item.submittedBy);
const suggestionSubmitterProfiles = await resolveSubmitterProfiles(suggestionSubmitterIds);

function toSuggestionRow(suggestion: AdminChangeSuggestionListItem): ChangeSuggestionTableRow {
  const profile = suggestionSubmitterProfiles.get(suggestion.submittedBy);
  return {
    id: suggestion.id,
    eventId: suggestion.eventId,
    eventName: suggestion.eventName,
    body: suggestion.body ?? "",
    status: suggestion.status,
    createdAt: suggestion.createdAt,
    submitterEmail: profile?.email ?? null,
    submitterLogin: profile?.login ?? null,
  };
}

const suggestionRows = rawSuggestions.map(toSuggestionRow);

function toAdminRow(event: Event, withSubmitter: boolean): AdminEventRow {
  const base = supabaseUrl
    ? enrichEventWithCoverUrl(event, supabaseUrl)
    : { ...event, coverUrl: null as string | null };

  if (!withSubmitter || !event.createdBy) {
    return base;
  }

  const profile = submitterProfiles.get(event.createdBy);
  return {
    ...base,
    submitterEmail: profile?.email ?? null,
    submitterLogin: profile?.login ?? null,
  };
}

const moderationEvents = fanPending.map((event) => toAdminRow(event, true));
const catalogEvents = otherEvents.map((event) => toAdminRow(event, false));
const listError = "error" in listResult ? listResult.error : null;
---

<Layout title="Panel admina">
  <AppShell showFooter={false}>
    <div class="mx-auto max-w-6xl px-2 py-8 sm:px-4">
      {
        listError ? (
          <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
            {listError}
          </p>
        ) : null
      }

      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class:list={shellHeading}>Panel admina</h1>
          <p class:list={["mt-1 text-sm", shellTextMuted]}>
            Moderacja zgłoszeń fanów i zarządzanie katalogiem wydarzeń.
          </p>
        </div>
        <a
          href={`${ADMIN_PATH}/events/new`}
          class:list={[shellBtnPrimary, "inline-flex h-10 shrink-0 items-center rounded-md px-4 text-sm"]}
        >
          Dodaj wydarzenie
        </a>
      </div>

      <section class="mb-12">
        <div class="mb-4">
          <h2 class="font-heading text-foreground text-xl font-bold tracking-tight uppercase">Sugestie zmian</h2>
          <p class:list={["mt-1 text-sm", shellTextMuted]}>
            Propozycje korekt od fanów – niezależnie od kolejki nowych zgłoszeń.
          </p>
        </div>
        {
          suggestionsError ? (
            <p class="mb-4 flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">
              {suggestionsError}
            </p>
          ) : null
        }
        <ChangeSuggestionsTable suggestions={suggestionRows} emptyMessage="Brak sugestii zmian." client:load />
      </section>

      <section class="mb-12">
        <div class="mb-4">
          <h2 class="font-heading text-foreground text-xl font-bold tracking-tight uppercase">Do moderacji</h2>
          <p class:list={["mt-1 text-sm", shellTextMuted]}>
            Zgłoszenia od użytkowników oczekujące na publikację lub odrzucenie.
          </p>
        </div>
        <AdminEventsTable
          events={moderationEvents}
          showSubmitter={true}
          showModerationActions={true}
          emptyMessage="Brak zgłoszeń do moderacji."
          client:load
        />
      </section>

      <section>
        <div class="mb-4">
          <h2 class="font-heading text-foreground text-xl font-bold tracking-tight uppercase">Wszystkie wydarzenia</h2>
          <p class:list={["mt-1 text-sm", shellTextMuted]}>
            {
              catalogEvents.length === 0
                ? "Brak pozostałych wydarzeń w bazie."
                : `Łącznie ${String(catalogEvents.length)} wydarzeń (sortowanie: od najbliższej daty).`
            }
          </p>
        </div>
        <AdminEventsTable
          events={catalogEvents}
          emptyMessage="Nie ma jeszcze opublikowanych ani szkicowych wydarzeń. Kliknij „Dodaj wydarzenie”, aby utworzyć pierwsze."
          client:load
        />
      </section>
    </div>
  </AppShell>
</Layout>
