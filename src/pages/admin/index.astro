---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";

export const prerender = false;

const { user } = Astro.locals;
---

<Layout title="Panel admina">
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 p-4 sm:p-8">
      <Topbar />

      <div class="mx-auto flex max-w-2xl flex-col items-center justify-center px-4 py-24 text-center">
        <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
          <h1
            class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
          >
            Panel admina
          </h1>
          <p class="text-blue-100/80">
            Zalogowano jako <span class="font-semibold text-white">{user?.email}</span>
          </p>
          <p class="mt-4 text-sm text-blue-100/60">
            Zarządzanie wydarzeniami (dodawanie, edycja, usuwanie) pojawi się w kolejnym kroku (S-01).
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
