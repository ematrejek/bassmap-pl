---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import AdminEventsTable from "@/components/admin/AdminEventsTable";
import { listEventsForAdmin } from "@/lib/services/events";
import { createClient } from "@/lib/supabase";

export const prerender = false;

const supabase = createClient(Astro.request.headers, Astro.cookies);
const events = supabase ? await listEventsForAdmin(supabase) : [];
---

<Layout title="Panel admina">
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 p-4 sm:p-8">
      <Topbar />

      <div class="mx-auto max-w-5xl px-2 py-8 sm:px-4">
        <AdminEventsTable events={events} />
      </div>
    </div>
  </div>
</Layout>
