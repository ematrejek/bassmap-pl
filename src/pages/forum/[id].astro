---
import GenreBadge from "@/components/fan/GenreBadge";
import ForumCommentsSection from "@/components/forum/ForumCommentsSection";
import AppShell from "@/components/shell/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { formatForumDate } from "@/lib/forum/format";
import { getForumSectionMeta } from "@/lib/forum/thread-schema";
import { FORUM_PATH } from "@/lib/routes";
import { shellBtnPrimary, shellLink } from "@/lib/shell-styles";
import { listForumComments } from "@/lib/services/forum-comments";
import { getForumThreadDetailForViewer } from "@/lib/services/forum-threads";
import { createClient } from "@/lib/supabase";
import { ThreadCrewJoinPanel } from "@/components/forum/ThreadCrewJoinPanel";

export const prerender = false;

const UUID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

const { id } = Astro.params;
const { user, isAdmin } = Astro.locals;
const isLoggedIn = Boolean(user);
const supabase = createClient(Astro.request.headers, Astro.cookies);

const isValidId = typeof id === "string" && UUID_PATTERN.test(id);
const threadDetailResult =
  supabase && isValidId ? await getForumThreadDetailForViewer(supabase, id, user?.id ?? null) : null;
const threadDetail = threadDetailResult && "data" in threadDetailResult ? threadDetailResult.data : null;
const thread = threadDetail?.thread ?? null;
const linkedCrew = threadDetail?.crew ?? null;

if (!thread) {
  Astro.response.status = 404;
}

const commentsResult = thread && supabase ? await listForumComments(supabase, thread.id) : null;
const initialComments = commentsResult && "data" in commentsResult ? commentsResult.data : [];

const sectionMeta = thread ? getForumSectionMeta(thread.category) : undefined;
const threadPath = thread ? `${FORUM_PATH}/${thread.id}` : FORUM_PATH;
---

<Layout title={thread ? `${thread.title} – Forum BassMap PL` : "Nie znaleziono – BassMap PL"}>
  <AppShell>
    <div class="mx-auto w-full max-w-2xl flex-1 px-2 py-8 sm:px-4">
      {
        !thread ? (
          <div class="surface-panel p-8 text-center">
            <h1 class="font-heading text-foreground text-2xl font-black uppercase">Nie znaleziono wątku</h1>
            <p class="text-muted-foreground mt-2">Ten wątek nie istnieje lub został usunięty.</p>
            <a
              href={FORUM_PATH}
              class:list={[shellBtnPrimary, "mt-6 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm"]}
            >
              Wróć na forum
            </a>
          </div>
        ) : (
          <article class="space-y-6">
            <a href={FORUM_PATH} class:list={[shellLink, "text-sm hover:underline"]}>
              &larr; Wróć na forum
            </a>

            <header class="space-y-3">
              <div class="flex flex-wrap items-center gap-2">
                {sectionMeta ? <GenreBadge color={sectionMeta.color}>{sectionMeta.label}</GenreBadge> : null}
              </div>

              <h1 class="font-heading text-foreground text-2xl font-black tracking-tight uppercase sm:text-3xl">
                {thread.title}
              </h1>

              <div class="text-muted-foreground flex flex-wrap items-center gap-x-4 gap-y-1 text-xs">
                <span class="text-accent font-mono">@{thread.authorLabel}</span>
                {thread.city ? <span>{thread.city}</span> : null}
                <time datetime={thread.createdAt}>{formatForumDate(thread.createdAt)}</time>
              </div>
            </header>

            <div class="surface-panel-flat p-5">
              <p class="text-foreground text-sm leading-relaxed whitespace-pre-wrap">{thread.body}</p>
            </div>

            {thread.crewId && isLoggedIn ? (
              <ThreadCrewJoinPanel client:only="react" crewId={thread.crewId} initialCrew={linkedCrew} />
            ) : null}

            <ForumCommentsSection
              client:load
              threadId={thread.id}
              initialComments={initialComments}
              isLoggedIn={isLoggedIn}
              isAdmin={isAdmin}
              currentUserId={user?.id ?? null}
              redirectPath={threadPath}
            />
          </article>
        )
      }
    </div>
  </AppShell>
</Layout>
